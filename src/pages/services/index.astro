---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="What We Do | R. West & Son">
  <Nav />

  <!-- Hero -->
  <section class="hero-gradient min-h-[60vh] flex items-center justify-center relative overflow-hidden hero-dots">
    <div class="absolute inset-0 z-[5] pointer-events-none opacity-60 md:opacity-30" style="background: radial-gradient(ellipse 50% 70% at center, rgba(253,249,243,0.95) 0%, rgba(253,249,243,0.8) 40%, rgba(253,249,243,0) 100%);"></div>
    <div class="relative z-10 text-center max-w-4xl mx-auto px-6 py-32">
      <div class="inline-flex items-center gap-2 bg-primary-container/10 px-4 py-1 rounded-full mb-8">
        <span class="text-primary font-label text-xs font-bold uppercase tracking-wider">&#9733; Our Services</span>
      </div>
      <h1 class="font-headline text-5xl md:text-7xl lg:text-[5.5rem] tracking-tighter leading-[0.9] mb-8">
        A single sculpture.<br /> A <span class="grad-maroon-text serif-italic">full factory.</span>
      </h1>
      <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        We build wooden crates, packing cases, and pallets for things that matter. Every one designed for the specific item inside it. If you need the whole job handled, collection through to shipping, that's what we're here for.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="grad-maroon-bg text-on-primary px-8 py-3.5 rounded-full font-label text-base font-bold uppercase tracking-widest hover:scale-105 transition-transform inline-block text-center">Tell Us What You Need</a>
        <a href="tel:01752664345" class="border-2 border-primary-container/20 text-primary px-8 py-3.5 rounded-full font-label text-base font-bold uppercase tracking-widest hover:bg-surface-container-low transition-colors inline-block text-center">Call Jason</a>
      </div>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="py-24 px-8 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 anim-up">
        <span class="inline-block grad-maroon-bg text-on-primary px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6">Three Clear Paths</span>
        <h2 class="font-headline text-4xl md:text-6xl tracking-tighter leading-none">
          Choose the service <span class="grad-maroon-text italic">you need.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 anim-stagger">
        <!-- Export Packing -->
        <a href="/services/export-packing" class="group bg-surface rounded-2xl overflow-hidden border border-outline-variant/30 hover:shadow-xl transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="h-56 overflow-hidden">
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="ISPM15 compliant export crate" src="/images/fb-foil-barrier.jpg" />
          </div>
          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-primary-container text-3xl">flight_takeoff</span>
              <span class="font-label text-xs font-bold uppercase tracking-widest text-primary">ISPM15-Compliant Shipping</span>
            </div>
            <h3 class="font-headline text-2xl mb-3">Export Packing</h3>
            <p class="text-on-surface-variant text-base leading-relaxed flex-1">
              Your goods need to cross a border? We handle heat-treated timber, certification marks, customs documentation, and shipping coordination. One company, your door to the destination.
            </p>
            <div class="mt-6 flex items-center gap-2 font-label text-sm font-bold uppercase tracking-widest grad-maroon-text group-hover:gap-4 transition-all">
              Learn more <span class="material-symbols-outlined text-lg">arrow_forward</span>
            </div>
          </div>
        </a>

        <!-- Wooden Packaging -->
        <a href="/services/wooden-packaging" class="group bg-surface rounded-2xl overflow-hidden border border-outline-variant/30 hover:shadow-xl transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="h-56 overflow-hidden">
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Custom wooden packing case" src="/images/cta-crates.jpg" />
          </div>
          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-primary-container text-3xl">package_2</span>
              <span class="font-label text-xs font-bold uppercase tracking-widest text-primary">Crates, Cases &amp; Pallets</span>
            </div>
            <h3 class="font-headline text-2xl mb-3">Wooden Packaging</h3>
            <p class="text-on-surface-variant text-base leading-relaxed flex-1">
              Every crate built around the item, not the other way round. CNC-cut foam inserts for fragile goods. Pallets to spec for production runs. And yes, we're happy to do just one.
            </p>
            <div class="mt-6 flex items-center gap-2 font-label text-sm font-bold uppercase tracking-widest grad-maroon-text group-hover:gap-4 transition-all">
              Learn more <span class="material-symbols-outlined text-lg">arrow_forward</span>
            </div>
          </div>
        </a>

        <!-- CNC Precision -->
        <a href="/services/cnc-services" class="group bg-surface rounded-2xl overflow-hidden border border-outline-variant/30 hover:shadow-xl transition-all duration-500 hover:-translate-y-1 flex flex-col">
          <div class="h-56 overflow-hidden">
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="CNC router cutting foam insert" src="/images/cnc-machine-branded.jpg" />
          </div>
          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-primary-container text-3xl">precision_manufacturing</span>
              <span class="font-label text-xs font-bold uppercase tracking-widest text-primary">Custom-Cut Inserts &amp; Panels</span>
            </div>
            <h3 class="font-headline text-2xl mb-3">CNC Precision</h3>
            <p class="text-on-surface-variant text-base leading-relaxed flex-1">
              Our CNC router cuts foam inserts and timber panels to exact dimensions. No gaps. No movement in transit. The machine is precise to fractions of a millimetre.
            </p>
            <div class="mt-6 flex items-center gap-2 font-label text-sm font-bold uppercase tracking-widest grad-maroon-text group-hover:gap-4 transition-all">
              Learn more <span class="material-symbols-outlined text-lg">arrow_forward</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- The Complete Service -->
  <section class="py-24 px-8">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="anim-up">
        <span class="inline-block grad-maroon-bg text-on-primary px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6">End to End</span>
        <h2 class="font-headline text-4xl md:text-6xl tracking-tighter leading-none mb-8">
          You don't need three <span class="grad-maroon-text italic">different companies.</span>
        </h2>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
          Most people come to us for a crate. They end up handing over the whole job. Collection from your premises in our own vehicle. Secure storage at our Ocean Quay workshop while you sort the shipping date. Packing, documentation, and shipping coordination. It's all one company. One phone number.
        </p>
        <div class="bg-surface-container-low rounded-lg p-6 border-l-4 border-primary-container">
          <blockquote class="font-headline text-lg italic leading-snug text-on-surface">
            "One less headache to deal with."
          </blockquote>
          <div class="mt-3">
            <p class="font-label font-bold uppercase tracking-widest text-xs">Steve Broadstock</p>
            <p class="text-on-surface-variant text-xs">Managing Director, British Fly Reels</p>
          </div>
        </div>
      </div>
      <div class="space-y-6 anim-up">
        <div class="flex items-start gap-5 bg-surface-container-low p-6 rounded-lg">
          <span class="material-symbols-outlined text-primary-container text-3xl mt-1">local_shipping</span>
          <div>
            <h3 class="font-headline text-lg mb-1">Collection</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">We collect from your premises in our own vehicle. No need to arrange separate transport.</p>
          </div>
        </div>
        <div class="flex items-start gap-5 bg-surface-container-low p-6 rounded-lg">
          <span class="material-symbols-outlined text-primary-container text-3xl mt-1">warehouse</span>
          <div>
            <h3 class="font-headline text-lg mb-1">Secure Storage</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">Hold at our Ocean Quay workshop until the shipping date is confirmed.</p>
          </div>
        </div>
        <div class="flex items-start gap-5 bg-surface-container-low p-6 rounded-lg">
          <span class="material-symbols-outlined text-primary-container text-3xl mt-1">package_2</span>
          <div>
            <h3 class="font-headline text-lg mb-1">Packing &amp; Documentation</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">ISPM15 crates, custom foam inserts, customs paperwork. All handled.</p>
          </div>
        </div>
        <div class="flex items-start gap-5 bg-surface-container-low p-6 rounded-lg">
          <span class="material-symbols-outlined text-primary-container text-3xl mt-1">public</span>
          <div>
            <h3 class="font-headline text-lg mb-1">Shipping Coordination</h3>
            <p class="text-on-surface-variant text-base leading-relaxed">Onward travel arranged through our network of hauliers and shipping companies.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom CTA for services overview -->
  <section class="py-12 px-8">
    <div class="grad-maroon-bg rounded-lg p-12 md:p-20 max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12 relative overflow-hidden anim-scale">
      <div class="relative z-10 max-w-2xl text-center md:text-left">
        <h2 class="font-headline text-5xl md:text-7xl text-white tracking-tighter leading-none mb-6">
          Not sure which service <span class="text-primary-fixed-dim italic">you need?</span>
        </h2>
        <p class="text-white/80 text-xl md:text-2xl font-headline mb-10">Tell us what you've got and where it's going. We'll work out the rest.</p>
        <div class="flex flex-col sm:flex-row gap-5">
          <a href="/contact" class="bg-white text-[#69001c] px-12 py-5 rounded-full font-label text-base font-bold uppercase tracking-widest hover:scale-105 transition-transform shadow-lg inline-block text-center">Tell Us About Your Item</a>
          <a href="tel:01752664345" class="border-2 border-white/40 text-white px-12 py-5 rounded-full font-label text-base font-bold uppercase tracking-widest hover:bg-white/15 transition-colors inline-block text-center">Call Jason</a>
        </div>
      </div>
      <div class="relative z-10 w-full md:w-1/3">
        <img class="w-full drop-shadow-2xl translate-y-8 rounded-lg" alt="Export wooden crates by R. West & Son" src="/images/cta-crates.jpg" />
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
