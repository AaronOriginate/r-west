---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'R. West & Son | Heritage Packaging Solutions' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preload" href="/r-west/fonts/Montserrat-Variable.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/r-west/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-fixed selection:text-primary">
  <slot />
  <script src="/r-west/scripts/animations.js" is:inline></script>
</body>
</html>
